# =====================================================================
# EXEMPLO DE CONFIGURAÇÕES DE AMBIENTE
# =====================================================================
# Copie este arquivo para .env.local e preencha com os valores reais
# cp .env.example .env.local

# =====================================================================
# OPENAI API CONFIGURATION
# =====================================================================
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_FREE=true

# =====================================================================
# GOOGLE SHEETS INTEGRATION
# =====================================================================
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Google Service Account Credentials (from JSON file)
GOOGLE_SERVICE_ACCOUNT_TYPE=service_account
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=your_project_id
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=your_private_key_id
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=your_client_id
GOOGLE_SERVICE_ACCOUNT_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_SERVICE_ACCOUNT_TOKEN_URI=https://oauth2.googleapis.com/token

# =====================================================================
# AUTHENTICATION
# =====================================================================
AI_TRANSLATE_PASSWORD=your_password_here

# =====================================================================
# APPLICATION SETTINGS
# =====================================================================
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =====================================================================
# DEVELOPMENT SETTINGS
# =====================================================================
NODE_ENV=development

# Disable Next.js telemetry locally
NEXT_TELEMETRY_DISABLED=1

# =====================================================================
# ECOMM PANEL AUTH E-MAIL
# =====================================================================
# SMTP config used by forgot-password and future token-by-email flows.
# If left empty, the panel keeps recovery working in development by
# exposing a debug token locally instead of sending mail.
PANEL_SMTP_HOST=
PANEL_SMTP_PORT=587
PANEL_SMTP_SECURE=false
PANEL_SMTP_USER=
PANEL_SMTP_PASSWORD=
PANEL_SMTP_TLS_INSECURE=false
PANEL_MAIL_FROM_NAME=EcommPanel
PANEL_MAIL_FROM_EMAIL=

# Optional public base URL used to build password-reset links in e-mail.
# If omitted, the app uses the current request origin.
PANEL_AUTH_BASE_URL=

# =====================================================================
# ECOMM PANEL DATABASE RUNTIME
# =====================================================================
# Controls how the admin runtime resolves the PostgreSQL connection:
# - auto     -> Uses Data Studio snapshot when provisioned; falls back to env if provided
# - snapshot -> Uses only the active connection saved by Data Studio
# - env      -> Uses only the variables below, ignoring Data Studio bootstrap flags
ECOMMPANEL_DB_RUNTIME_MODE=auto

# Runtime connection values for local development or for forcing a remote DB.
# For local + remote VPS, prefer using an SSH tunnel and keep APP_DB_HOST as 127.0.0.1.
APP_DB_LABEL=Postgres local de desenvolvimento
APP_DB_HOST=127.0.0.1
APP_DB_PORT=5432
APP_DB_NAME=app_hub
APP_DB_USER=app_hub
APP_DB_PASSWORD=
APP_DB_SSL_MODE=disable

# Optional SSH tunnel helper for local development against a remote VPS database.
# Example:
# 1) export PANEL_DB_TUNNEL_HOST=31.97.247.139
# 2) export PANEL_DB_TUNNEL_USER=root
# 3) export PANEL_DB_LOCAL_PORT=55432
# 4) npm run panel:db:tunnel
# 5) set APP_DB_HOST=127.0.0.1 and APP_DB_PORT=55432
PANEL_DB_TUNNEL_HOST=
PANEL_DB_TUNNEL_PORT=22
PANEL_DB_TUNNEL_USER=root
PANEL_DB_REMOTE_HOST=127.0.0.1
PANEL_DB_REMOTE_PORT=5432
PANEL_DB_LOCAL_PORT=55432

# =====================================================================
# ECOMM PANEL <-> ECOMMERCE FILE BRIDGE (OPTIONAL)
# =====================================================================
# Shared directory used by EcommPanel to publish dynamic pages and by
# Ecommerce to read published snapshots.
# If omitted, default path is: src/data/site-runtime
ECOM_CONTENT_PATH=

# Panel settings persistence mode:
# - files    -> keeps admin settings only in workspace JSON files
# - hybrid   -> prefers PostgreSQL for admin settings and keeps file/runtime mirrors in sync
# - database -> uses PostgreSQL as source of truth for admin settings
ECOM_PANEL_SETTINGS_PERSISTENCE_MODE=hybrid

# Analytics events persistence mode:
# - files    -> mantém eventos brutos apenas em arquivos ndjson
# - hybrid   -> prefere PostgreSQL no dashboard e mantém arquivos como espelho/fallback
# - database -> usa PostgreSQL como fonte principal dos eventos e ignora arquivos no runtime analítico
ECOM_ANALYTICS_EVENTS_PERSISTENCE_MODE=hybrid

# Site builder persistence mode:
# - files    -> uses only JSON/admin files for dynamic pages and routes
# - hybrid   -> prefers PostgreSQL in the admin and keeps published snapshots in sync
# - database -> uses PostgreSQL as source of truth for admin operations and updates snapshots for storefront runtime
ECOM_SITE_PERSISTENCE_MODE=hybrid

# Storefront structural persistence mode:
# - files    -> uses only JSON/admin files for template, theme, texts and mega menu
# - hybrid   -> prefers PostgreSQL in the admin and keeps the published storefront snapshot in sync
# - database -> uses PostgreSQL as source of truth for admin operations and updates the published snapshot for storefront runtime
ECOM_STOREFRONT_PERSISTENCE_MODE=hybrid

# Blog persistence mode:
# - files    -> uses only JSON/runtime files
# - hybrid   -> prefers PostgreSQL and falls back to files; can seed DB from files
# - database -> uses only PostgreSQL and ignores file snapshots as runtime source
ECOM_BLOG_PERSISTENCE_MODE=hybrid

# =====================================================================
# E-COMMERCE DATA SOURCE (LOCAL | VTEX MOCK | VTEX LIVE)
# =====================================================================
# Controls which backend the ecommerce uses. No code changes are required—only flip this value:
# - app      → Uses the project's own public API/runtime (recommended for panel + DB/file hybrid)
# - local    → Uses local JSON and mock data (best for offline/dev and tests)
# - vtexMock → Uses VTEX-like mock gateway for quick demos
# - vtexLive → Uses VTEX via the built-in BFF/proxy routes
NEXT_PUBLIC_DATA_SOURCE=app

# Catalog persistence mode:
# - files    -> uses only JSON/admin files for the catalog
# - hybrid   -> prefers PostgreSQL and falls back to files; can seed DB from files
# - database -> uses only PostgreSQL and ignores catalog files as runtime source
ECOM_CATALOG_PERSISTENCE_MODE=hybrid

# =====================================================================
# VTEX CONFIGURATION (Required only when NEXT_PUBLIC_DATA_SOURCE=vtexLive)
# =====================================================================
# Where to find these values
# - VTEX_ACCOUNT: Your VTEX account name (e.g., myaccount)
# - VTEX_ENV: Usually vtexcommercestable (default) or vtexcommercebeta
# - VTEX_APP_KEY / VTEX_APP_TOKEN: Create in VTEX Admin → Account Management → Application Keys
#   Grant permissions to Catalog, Checkout, and (optionally) GraphQL depending on your usage.
#
# After setting these, run the app. The UI will fetch:
# - Products/Search/Categories: via /api/vtex/*
# - Checkout (shipping simulation, etc.): via /api/vtex/checkout/*
#
# TIP: Do NOT expose these on the client. Keep them server-side only (no NEXT_PUBLIC_ prefix).
VTEX_ACCOUNT=your_vtex_account
VTEX_ENV=vtexcommercestable
VTEX_APP_KEY=your_app_key
VTEX_APP_TOKEN=your_app_token

# Optionally, override VTEX base URL (otherwise it's built from VTEX_ACCOUNT + VTEX_ENV)
# Example: https://your-account.vtexcommercestable.com.br
VTEX_BASE_URL=

# Example switching to VTEX live
# 1) Duplicate this file to .env.local and fill in the VTEX_* values above
# 2) Set NEXT_PUBLIC_DATA_SOURCE=vtexLive
# 3) Restart the dev server after changes to environment variables
# 4) Start the app; Departments, PLP, PDP, and shipping simulation will use VTEX
#
# Never commit .env.local to version control.
